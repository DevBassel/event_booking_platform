---
id: 683b7c23-da7f-46a4-80fb-3ca81c02ae33
---
erDiagram
    TENANTS {
        uuid id PK "primary key"
        string name
        string plan
        string status
        timestamptz created_at
        timestamptz updated_at
    }

    USERS {
        uuid id PK
        uuid tenant_id FK
        string email
        string name
        string password_hash
        bool is_admin
        timestamptz created_at
        timestamptz updated_at
    }

    EVENTS {
        uuid id PK
        uuid tenant_id FK
        uuid organizer_id FK "references USERS or separate organizers table"
        string title
        string slug
        text description
        timestamptz starts_at
        timestamptz ends_at
        string venue
        bool is_public
        timestamptz created_at
        timestamptz updated_at
    }

    TICKETS {
        uuid id PK
        uuid event_id FK
        string name
        int price
        int quantity
        int remaining
        bool is_active
        timestamptz created_at
        timestamptz updated_at
    }

    BOOKINGS {
        uuid id PK
        uuid user_id FK
        uuid ticket_id FK
        uuid payment_id FK
        string status "pending / confirmed / cancelled / refunded"
        int quantity
        decimal total_amount
        timestamptz created_at
        timestamptz updated_at
    }

    PAYMENTS {
        uuid id PK
        uuid tenant_id FK
        uuid booking_id FK
        decimal amount
        string provider "stripe/paymob/paypal/..."
        string provider_payment_id
        string status
        json metadata
        timestamptz created_at
    }

    EVENT_IMAGES {
        uuid id PK
        uuid event_id FK
        string url
        string type
        timestamptz created_at
    }

    PROMO_CODES {
        uuid id PK
        uuid tenant_id FK
        string code
        decimal discount_amount
        decimal discount_percent
        timestamptz valid_from
        timestamptz valid_to
        int usage_limit
        int used_count
    }

    NOTIFICATIONS {
        uuid id PK
        uuid tenant_id FK
        uuid user_id FK
        string channel "email/sms/push"
        string status
        json payload
        timestamptz created_at
    }

    AUDIT_LOGS {
        uuid id PK
        uuid tenant_id FK
        uuid actor_id FK
        string action
        json details
        timestamptz created_at
    }

    TENANTS ||--o{ USERS : "has"
    TENANTS ||--o{ EVENTS : "owns"
    TENANTS ||--o{ PAYMENTS : "receives"
    TENANTS ||--o{ PROMO_CODES : "creates"

    USERS ||--o{ BOOKINGS : "makes"
    USERS ||--o{ EVENTS : "organizes"

    EVENTS ||--o{ TICKETS : "offers"
    EVENTS ||--o{ EVENT_IMAGES : "has"

// [MermaidChart: 683b7c23-da7f-46a4-80fb-3ca81c02ae33]
    TICKETS ||--o{ BOOKINGS : "booked_via"

    BOOKINGS ||--|| PAYMENTS : "may_be_paid_by"

    EVENTS ||--o{ PROMO_CODES : "may_use"

    TENANTS ||--o{ NOTIFICATIONS : "generates"
    USERS ||--o{ NOTIFICATIONS : "receives"

    TENANTS ||--o{ AUDIT_LOGS : "logs"